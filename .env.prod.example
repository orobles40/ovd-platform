# OVD Platform — Variables de entorno producción
# Copyright 2026 Omar Robles
#
# Copiar a .env.prod y completar los valores.
# Los valores SECRETOS (API keys, passwords) NO van aquí — usar Docker Secrets.
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ---------------------------------------------------------------------------
# Dominio y TLS (C09 — completar antes de activar Caddy en producción)
# ---------------------------------------------------------------------------
DOMAIN=ovd.omarrobles.dev
# URL del engine inyectada en el build del dashboard (Vite build-time)
VITE_API_URL=https://ovd.omarrobles.dev

# ---------------------------------------------------------------------------
# Versiones de imagen
# ---------------------------------------------------------------------------
OVD_ENGINE_VERSION=latest
OVD_DASHBOARD_VERSION=latest

# ---------------------------------------------------------------------------
# LLM — Claude (Anthropic) — API key va en Docker Secret 'anthropic_api_key'
# ---------------------------------------------------------------------------
OVD_MODEL=claude-sonnet-4-6
# OVD_MODEL_ANALYZER=claude-haiku-4-5-20251001
# OVD_MODEL_SDD=claude-sonnet-4-6
# OVD_MODEL_QA=claude-sonnet-4-6
OVD_LLM_TIMEOUT_SECS=300

# ---------------------------------------------------------------------------
# LLM — Ollama (RunPod RTX 4090 on-demand — Config B)
# Dejar vacío si la instancia RunPod no está activa
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=
OVD_RAG_EMBEDDING_PROVIDER=openai

# ---------------------------------------------------------------------------
# Observabilidad
# ---------------------------------------------------------------------------
LOG_LEVEL=info
OVD_QA_ALERT_THRESHOLD=70

# LangSmith tracing (opcional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ovd-platform-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
