# OVD Platform — Variables de entorno producción
# Copyright 2026 Omar Robles
#
# Copiar a .env.prod y completar los valores.
# Los valores SECRETOS (API keys, passwords) NO van aquí — usar Docker Secrets.
# Ver: docs/DEPLOYMENT.md

# ---------------------------------------------------------------------------
# Versiones de imagen
# ---------------------------------------------------------------------------
OVD_ENGINE_VERSION=latest
OVD_BRIDGE_VERSION=latest

# ---------------------------------------------------------------------------
# Modelo LLM
# ---------------------------------------------------------------------------
OVD_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# QA Alert threshold (dispara webhook qa.score_low si score < umbral)
# ---------------------------------------------------------------------------
OVD_QA_ALERT_THRESHOLD=70

# ---------------------------------------------------------------------------
# LangSmith tracing (opcional)
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ovd-platform-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---------------------------------------------------------------------------
# RAG embedding provider (openai | ollama)
# ---------------------------------------------------------------------------
OVD_RAG_EMBEDDING_PROVIDER=openai

# ---------------------------------------------------------------------------
# Ollama (solo si OVD_RAG_EMBEDDING_PROVIDER=ollama)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://ollama:11434
