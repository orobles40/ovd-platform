# OVD Platform — Variables de entorno producción
# Copyright 2026 Omar Robles
#
# Copiar a .env.prod y completar los valores.
# Los valores SECRETOS (API keys, passwords) NO van aquí — usar Docker Secrets.
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# ── Secrets (Docker Secrets — NO poner aquí) ─────────────────────────────────
#   anthropic_api_key → echo "sk-ant-..." | docker secret create anthropic_api_key -
#   db_password       → echo "PASS_SEGURA" | docker secret create db_password -
#   ovd_engine_secret → openssl rand -hex 32 | docker secret create ovd_engine_secret -
#   openai_api_key    → echo "sk-..." | docker secret create openai_api_key -  (si RAG=openai)

# ---------------------------------------------------------------------------
# Dominio y TLS — completar antes del primer deploy
# ---------------------------------------------------------------------------
DOMAIN=ovd.omarrobles.dev
# URL pública del engine — inyectada en el build del dashboard (Vite build-time)
VITE_API_URL=https://ovd.omarrobles.dev

# ---------------------------------------------------------------------------
# CORS — orígenes permitidos para el dashboard
# Separados por coma. Debe incluir el dominio real de producción.
# ---------------------------------------------------------------------------
OVD_CORS_ORIGINS=https://ovd.omarrobles.dev,http://localhost:5173

# ---------------------------------------------------------------------------
# Versiones de imagen
# ---------------------------------------------------------------------------
OVD_ENGINE_VERSION=latest
OVD_DASHBOARD_VERSION=latest

# ---------------------------------------------------------------------------
# LLM — Claude (Anthropic) — API key va en Docker Secret 'anthropic_api_key'
# ---------------------------------------------------------------------------
OVD_MODEL=claude-sonnet-4-6
# OVD_MODEL_ANALYZER=claude-haiku-4-5-20251001
# OVD_MODEL_SDD=claude-sonnet-4-6
# OVD_MODEL_QA=claude-sonnet-4-6
OVD_LLM_TIMEOUT_SECS=300

# ---------------------------------------------------------------------------
# RAG — Embeddings
#
# OVD_RAG_EMBEDDING_PROVIDER:
#   "openai"  → text-embedding-3-small (~$0.02/1M tokens). Requiere OPENAI_API_KEY.
#               Recomendado para VPS sin GPU.
#   "ollama"  → nomic-embed-text local. Requiere OLLAMA_BASE_URL accesible.
#               Recomendado si tienes RunPod/GPU on-demand.
# ---------------------------------------------------------------------------
OVD_RAG_EMBEDDING_PROVIDER=openai
OVD_EMBED_MODEL=text-embedding-3-small
# OPENAI_API_KEY va en Docker Secret 'openai_api_key' — NO aquí

# Ollama (RunPod RTX 4090 on-demand — Config B alternativa)
# Dejar vacío si OVD_RAG_EMBEDDING_PROVIDER=openai
OLLAMA_BASE_URL=

# ---------------------------------------------------------------------------
# Observabilidad
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# LangSmith tracing (opcional — para debug de agentes)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ovd-platform-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
