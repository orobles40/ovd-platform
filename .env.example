# OVD Platform — Variables de entorno
# Copia este archivo a .env y completa los valores marcados con [REQUIRED]
# NUNCA comitear .env — esta en .gitignore
#
# Tiempo estimado de configuracion inicial: ~20 minutos
# Para credenciales Oracle contactar al DBA del equipo
# Variables marcadas [OPTIONAL] tienen valor por defecto funcional

# =============================================================================
# AI PROVIDERS — al menos uno requerido
# =============================================================================

# [REQUIRED] Anthropic — modelo principal de los agentes OVD
ANTHROPIC_API_KEY=sk-ant-...

# [OPTIONAL] Modelo base para los ciclos OVD (puede sobreescribirse por org/proyecto via Model Registry)
# Opciones: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
OVD_MODEL=claude-sonnet-4-6

# [OPTIONAL] OpenAI — solo para fine-tuning alternativo o comparacion de modelos
OPENAI_API_KEY=

# =============================================================================
# BASE DE DATOS PRINCIPAL (PostgreSQL 16 + pgvector)
# =============================================================================

# URL completa de conexion
DATABASE_URL=postgresql://ovd_dev:changeme@localhost:5432/ovd_dev

# Rol de solo lectura para MCP PostgreSQL en produccion
DATABASE_READONLY_URL=postgresql://ovd_readonly:changeme@localhost:5432/ovd_dev

# =============================================================================
# AUTH / JWT
# =============================================================================

# Secret para firmar JWT (minimo 32 caracteres, generar con: openssl rand -hex 32)
JWT_SECRET=

# Duracion del token de acceso
JWT_ACCESS_EXPIRES=8h

# Duracion del token de refresh
JWT_REFRESH_EXPIRES=30d

# =============================================================================
# OVD ENGINE (LangGraph — Python)
# =============================================================================

# URL del OVD Engine visto desde el Bridge
OVD_ENGINE_URL=http://localhost:8001

# Timeout para llamadas del Bridge al Engine (ms)
OVD_ENGINE_TIMEOUT=30000

# [REQUIRED en produccion] Secret compartido entre Bridge y Engine (header X-OVD-Secret)
# Dejar vacio solo en desarrollo local (desactiva la autenticacion interna)
# Generar con: openssl rand -hex 32
OVD_ENGINE_SECRET=

# URL del Bridge vista desde el Engine (para RAG callbacks y Research Agent)
OVD_BRIDGE_URL=http://localhost:3000

# [OPTIONAL] JWT de servicio para que el Engine llame al Bridge
# Necesario para: RAG seed automatico, Research Agent
OVD_TOKEN=

# =============================================================================
# ORACLE MULTI-SEDE (Alemana)
# =============================================================================
# IMPORTANTE: Solicitar credenciales al DBA. No adivinar estos valores.
# Los wallets Oracle deben estar fuera del repositorio.

# Directorio de Oracle Wallets (fuera del repo, ruta absoluta)
ORACLE_WALLET_DIR=/opt/oracle/wallets

# CAS — Casa Matriz (Oracle 12c)
ORACLE_CAS_DSN=
ORACLE_CAS_USER=
ORACLE_CAS_PASSWORD=

# CAT — Catedral (Oracle 19c)
ORACLE_CAT_DSN=
ORACLE_CAT_USER=
ORACLE_CAT_PASSWORD=

# CAV — Cavour (Oracle 19c)
ORACLE_CAV_DSN=
ORACLE_CAV_USER=
ORACLE_CAV_PASSWORD=

# Pool de conexiones por sede (maximo conexiones simultaneas)
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# =============================================================================
# NATS JETSTREAM
# =============================================================================

NATS_URL=nats://localhost:4222

# Credenciales NATS (si el servidor tiene autenticacion)
NATS_USER=
NATS_PASSWORD=

# Archivo de credenciales NATS (alternativa a user/password)
NATS_CREDS_FILE=

# Stream principal para eventos OVD
NATS_STREAM=ovd-events
NATS_CONSUMER=ovd-tui

# =============================================================================
# OPENTELEMETRY (Telemetria)
# =============================================================================

# Endpoint del OTEL Collector local
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Nombre del servicio en las trazas
OTEL_SERVICE_NAME=ovd-platform

# Habilitar telemetria (true/false)
OTEL_ENABLED=true

# =============================================================================
# RAG — pgvector (Retrieval-Augmented Generation)
# =============================================================================

# Activar sistema RAG para contexto de proyecto en los agentes
OVD_RAG_ENABLED=true

# Proveedor de embeddings: anthropic | openai | ollama
OVD_EMBEDDING_PROVIDER=anthropic

# Modelo de embeddings (debe coincidir con OVD_EMBEDDING_DIMS)
# anthropic → voyage-3 (dims: 1024)
# openai    → text-embedding-3-small (dims: 1536)
# ollama    → nomic-embed-text (dims: 768)
OVD_EMBEDDING_MODEL=voyage-3

# Dimensiones del vector — debe coincidir con la columna pgvector
OVD_EMBEDDING_DIMS=1024

# Score minimo de similitud para incluir un resultado RAG (0.0 - 1.0)
OVD_RAG_MIN_SCORE=0.65

# Numero maximo de chunks RAG por query
OVD_RAG_TOP_K=5

# Tamaño maximo de archivo a indexar en KB
OVD_RAG_MAX_FILE_KB=512

# =============================================================================
# RATE LIMITING (Bridge)
# =============================================================================

# Maximo de requests globales por ventana de tiempo
OVD_RATE_LIMIT_MAX=100

# Maximo de requests por organizacion por ventana
OVD_RATE_LIMIT_MAX_ORG=50

# Ventana de tiempo en ms (default: 60 segundos)
OVD_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# MULTI-TENANCY
# =============================================================================

# ID de la organizacion por defecto (desarrollo local)
DEFAULT_ORG_ID=omar-dev

# Nombre de la organizacion por defecto
DEFAULT_ORG_NAME=Omar Robles Dev

# =============================================================================
# GITHUB (MCP GitHub — para gestion del fork)
# =============================================================================

# Personal Access Token con scope: repo, read:org
GITHUB_TOKEN=

# Repositorio del fork (org/repo)
GITHUB_REPO=omar/ovd-platform

# =============================================================================
# CONFLUENCE (documentacion interna Alemana)
# =============================================================================

CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=

# =============================================================================
# FINE-TUNING PIPELINE
# =============================================================================

# Modelo base para fine-tuning con Anthropic
OVD_FINETUNE_BASE_MODEL=claude-haiku-4-5-20251001

# Directorio para guardar datasets de entrenamiento (fuera del repo)
FINETUNE_DATA_DIR=/opt/ovd/finetune/data

# Umbral de calidad para auto-rechazo de ciclos en el dataset (0-1)
FINETUNE_MIN_QUALITY=0.7

# API de RunPod (para training jobs en GPU remota — opcional)
RUNPOD_API_KEY=

# =============================================================================
# OLLAMA — modelos OSS locales (fine-tuning OSS via Unsloth/LlamaFactory)
# =============================================================================

OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# LANGSMITH — tracing de llamadas LLM (GAP-010)
# Obtener API key en: https://smith.langchain.com
# =============================================================================

# Activar tracing (false por defecto para no incurrir en costos accidentales)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ovd-platform
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# INFISICAL — Secrets Manager auto-hosteado (Sprint 9)
# Activar con: docker compose --profile infisical up -d
# Setup inicial: http://localhost:8080
# =============================================================================

# Generar con: openssl rand -hex 32
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=
INFISICAL_DB_PASSWORD=infisical_dev
INFISICAL_SITE_URL=http://localhost:8080
# Token de Machine Identity (crear en Infisical → Settings → Machine Identities)
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
# SMTP (opcional)
INFISICAL_SMTP_HOST=
INFISICAL_SMTP_PORT=587
INFISICAL_SMTP_USERNAME=
INFISICAL_SMTP_PASSWORD=
INFISICAL_SMTP_FROM=noreply@localhost

# =============================================================================
# OVD QA / SECURITY — umbrales de auto-aprobación (Sprint 5)
# =============================================================================

# Score mínimo de QA para auto-aprobar ciclos (0-100)
OVD_QA_MIN_SCORE=60
# Score mínimo de security
OVD_SECURITY_MIN_SCORE=50
# Timeout del ciclo completo en segundos
OVD_CYCLE_TIMEOUT_SECS=600

# =============================================================================
# OVD API PÚBLICA — JWT (Sprint 12)
# =============================================================================

# Secret para JWT (mínimo 64 hex chars, generar con: openssl rand -hex 32)
JWT_SECRET=

# =============================================================================
# OVD DASHBOARD (src/dashboard)
# Puerto de desarrollo: 5173
# En producción apuntar VITE_API_BASE_URL al engine real
# =============================================================================

VITE_API_BASE_URL=http://localhost:8001

# =============================================================================
# DESARROLLO LOCAL
# =============================================================================

# Entorno (development | staging | production)
NODE_ENV=development

# Puerto del servidor Hono (fork OpenCode)
PORT=3000

# Puerto OVD Engine
OVD_ENGINE_PORT=8001

# Habilitar modo debug
DEBUG=false

# Nivel de log (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL=DEBUG
