    <!-- Nota 1: TUI -->
    <mxCell id="101" value="&lt;b&gt;TUI — Terminal UI (Rust)&lt;/b&gt;&lt;br&gt;Binario standalone multiplataforma (macOS ARM/x86,&lt;br&gt;Linux, Windows). Consume la misma FastAPI.&lt;br&gt;&lt;br&gt;• &lt;b&gt;--from-file &amp;lt;ruta&amp;gt;&lt;/b&gt;: carga un .md como FR al iniciar&lt;br&gt;• &lt;b&gt;Ctrl+O&lt;/b&gt;: carga de archivo interactiva en formulario&lt;br&gt;• Aprobación SDD: aprobar / revisar / rechazar&lt;br&gt;• DeliveryScreen: resumen de artefactos generados"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="50" y="1150" width="290" height="165" as="geometry"/>
    </mxCell>
    <mxCell id="101a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="101" target="4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 2: Dashboard -->
    <mxCell id="102" value="&lt;b&gt;Dashboard Web (React)&lt;/b&gt;&lt;br&gt;Interfaz de administración completa.&lt;br&gt;Roles: admin / developer / viewer.&lt;br&gt;&lt;br&gt;• Lanzador FR con streaming SSE en vivo&lt;br&gt;• Panel de aprobaciones con polling 10s&lt;br&gt;• Telemetría: QA trend, costo, tokens/agente&lt;br&gt;• RAG Bootstrap: indexar documentos al cliente&lt;br&gt;• &lt;b&gt;/admin/skills&lt;/b&gt;: actualizar repos externos"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="370" y="1150" width="290" height="165" as="geometry"/>
    </mxCell>
    <mxCell id="102a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="102" target="5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 3: Auth + Multi-tenancy -->
    <mxCell id="103" value="&lt;b&gt;Auth + Multi-tenancy&lt;/b&gt;&lt;br&gt;JWT HS256 (access 1h) + refresh token 7d.&lt;br&gt;Roles: admin / developer / viewer.&lt;br&gt;Rate limiting en endpoints de autenticación.&lt;br&gt;&lt;br&gt;• RLS activado en 13 tablas OVD&lt;br&gt;• Toda query filtra por &lt;b&gt;org_id&lt;/b&gt;&lt;br&gt;• AuditLogger registra acceso a secrets&lt;br&gt;• Aislamiento garantizado a nivel de BD"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="690" y="1150" width="290" height="165" as="geometry"/>
    </mxCell>
    <mxCell id="103a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="103" target="7" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 4: human_approval (INTERRUPT) -->
    <mxCell id="104" value="&lt;b&gt;human_approval — INTERRUPT&lt;/b&gt;&lt;br&gt;El grafo se pausa aquí esperando al arquitecto.&lt;br&gt;El estado persiste en PostgreSQL (checkpointer)&lt;br&gt;— puede retomarse días después.&lt;br&gt;&lt;br&gt;• &lt;b&gt;Aprobar&lt;/b&gt;: continúa al fan-out de agentes&lt;br&gt;• &lt;b&gt;Revisar&lt;/b&gt;: vuelve a generate_sdd con feedback&lt;br&gt;• &lt;b&gt;Rechazar&lt;/b&gt;: termina el ciclo&lt;br&gt;• Historial de revisiones acumulado"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="1010" y="1150" width="290" height="165" as="geometry"/>
    </mxCell>
    <mxCell id="104a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#d6b656;"
      edge="1" source="104" target="12" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 5: Agentes especializados -->
    <mxCell id="105" value="&lt;b&gt;Agentes especializados (tool calling)&lt;/b&gt;&lt;br&gt;Se ejecutan en paralelo vía LangGraph Send().&lt;br&gt;Cada agente usa &lt;b&gt;bind_tools()&lt;/b&gt; con:&lt;br&gt;&lt;br&gt;• write_file / read_file / edit_file / list_files&lt;br&gt;• &lt;b&gt;context7&lt;/b&gt;: docs de librerías en tiempo real&lt;br&gt;• Leen archivos existentes antes de escribir&lt;br&gt;• System prompts con metodología Superpowers:&lt;br&gt;  TDD iron law + verification-before-completion"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="50" y="1340" width="310" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="105a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="105" target="14" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 6: Security + QA -->
    <mxCell id="106" value="&lt;b&gt;security_audit + qa_review&lt;/b&gt;&lt;br&gt;Nodos independientes post fan-out.&lt;br&gt;&lt;br&gt;Security revisa:&lt;br&gt;• OWASP Top 10 · secrets · RLS bypass · SSRF&lt;br&gt;• Score 0-100, severity: none/low/medium/high&lt;br&gt;&lt;br&gt;QA revisa:&lt;br&gt;• Cumplimiento SDD · calidad · TDD checklist&lt;br&gt;• Si falla: retry ≤3 veces → escala a humano"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="390" y="1340" width="310" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="106a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="106" target="19" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 7: PostgreSQL -->
    <mxCell id="107" value="&lt;b&gt;PostgreSQL + pgvector (Docker)&lt;/b&gt;&lt;br&gt;Tres roles críticos simultáneos:&lt;br&gt;&lt;br&gt;• &lt;b&gt;Checkpointer LangGraph&lt;/b&gt;: persiste estado del grafo&lt;br&gt;  entre sesiones (human_approval puede durar días)&lt;br&gt;• &lt;b&gt;pgvector&lt;/b&gt;: almacena embeddings RAG por proyecto&lt;br&gt;• &lt;b&gt;RLS en 13 tablas&lt;/b&gt;: aislamiento multi-tenant&lt;br&gt;&lt;br&gt;⚠ Sin restart policy — iniciar manualmente:&lt;br&gt;&lt;code&gt;docker start postgres_db&lt;/code&gt;"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="730" y="1340" width="310" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="107a" style="dashed=1;endArrow=open;endFill=0;strokeColor=#999900;"
      edge="1" source="107" target="30" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Nota 8: RAG + context7 -->
    <mxCell id="108" value="&lt;b&gt;RAG + MCP context7&lt;/b&gt;&lt;br&gt;RAG indexa: código, docs, contratos, tickets,&lt;br&gt;informes de entrega del proyecto.&lt;br&gt;&lt;br&gt;• Inyecta {rag_context} en SDD y agentes&lt;br&gt;• Bootstrap: 1617+ chunks (docs/ + src/engine/)&lt;br&gt;&lt;br&gt;context7 (MCP) complementa el RAG:&lt;br&gt;• Resuelve docs de librerías externas en tiempo real&lt;br&gt;• No requiere indexar cada librería manualmente&lt;br&gt;• Inicia con el engine vía npx stdio"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#999900;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="1070" y="1340" width="310" height="175" as="geometry"/>
    </mxCell>
